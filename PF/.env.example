# MongoDB Atlas
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/paper_foundation?retryWrites=true&w=majority"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate with: openssl rand -base64 32"

# Admin credentials (single admin)
ADMIN_EMAIL="admin@paperfoundation.in"
# Generate hash with: npm run hash-password -- yourPlaintextPassword
ADMIN_PASSWORD_HASH="$2a$10$replace_with_real_bcrypt_hash"
ADMIN_NAME="Paper Foundation Admin"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Public site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
